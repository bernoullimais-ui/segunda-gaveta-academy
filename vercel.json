{
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "api/index.ts", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/public/curso/:slug", "destination": "/api/index.ts" },
    { "source": "/public/trilha/:slug", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/recover-carts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/expire-access",
      "schedule": "0 3 * * *"
    }
  ]
}
