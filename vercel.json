{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/public/curso/:slug", "destination": "/api/index" },
    { "source": "/public/trilha/:slug", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/recover-carts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/expire-access",
      "schedule": "0 3 * * *"
    }
  ]
}
